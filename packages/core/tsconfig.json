{
  "compilerOptions": {
    "module": "CommonJS",
    "declaration": true,
    "outDir": "./dist",
    "strict": true,
    "target": "ES2021",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["src/**/*", "test/**/*", "vitest.config.ts"]
}
