{
  "name": "@nexus/plugin-sdk",
  "version": "0.0.1",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.build.json && tsc -p tsconfig.type-tests.json",
