# Force devDependencies to be installed regardless of NODE_ENV.
# The lint and build gates require dev tooling (eslint, globals, typescript-eslint,
# @next/eslint-plugin-next, vitest, etc.). Without this override, running
# `npm install` in a `NODE_ENV=production` environment omits devDependencies
# and the in-container quality gate fails with ERR_MODULE_NOT_FOUND.
include=dev
