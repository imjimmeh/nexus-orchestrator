{
  "name": "api",
  "version": "0.0.1",
  "description": "Foundational API for the Nexus Orchestrator system, built with NestJS.",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "cross-env NODE_OPTIONS=--max-old-space-size=3584 eslint \"{src,apps,libs,test}/**/*.ts\" --cache --cache-location .eslintcache --fix",
    "test": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:boot": "vitest run --project boot",
    "test:watch": "vitest --project unit",
    "test:cov": "vitest run --coverage --project unit",
    "test:debug": "node --inspect-brk ./node_modules/vitest/vitest.mjs --run --project unit --no-file-parallelism",
    "test:e2e": "vitest run --project e2e",
    "test:e2e:kanban:deterministic": "vitest run --project e2e test/kanban-lifecycle-deterministic.e2e-spec.ts",
    "seed:workflows": "ts-node -r reflect-metadata --project tsconfig.json src/database/seeds/seed-workflows.cli.ts",
    "validate:seed-data": "vitest run --project unit src/database/seeds/seed-data.validation.spec.ts",
    "madge:circular": "madge --circular --extensions ts src",
    "madge:ci": "node scripts/check-circular.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1069.0",
    "@earendil-works/pi-ai": "^0.78.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.24",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.24",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.24",
    "@nestjs/platform-socket.io": "^11.1.24",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.1",
    "@nestjs/websockets": "^11.1.24",
    "@nexus/core": "*",
    "@nexus/gitops-contracts": "*",
    "@nexus/kanban-contracts": "*",
    "@nexus/plugin-sdk": "*",
    "@octokit/rest": "^22.0.1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "axios": "^1.17.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.77.7",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dockerode": "^5.0.0",
    "expr-eval": "^2.0.2",
    "handlebars": "^4.7.9",
    "ioredis": "^5.11.0",
    "js-yaml": "^4.2.0",
    "jsonwebtoken": "^9.0.3",
    "mammoth": "^1.12.0",
    "nest-winston": "^1.10.2",
    "nodemailer": "^9.0.3",
    "openai": "^6.39.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdf-parse": "^2.4.5",
    "pg": "^8.21.0",
    "playwright": "^1.60.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "tar-stream": "^3.2.0",
    "tiktoken": "^1.0.22",
    "typeorm": "^1.0.0",
    "winston": "^3.19.0",
    "yaml": "^2.7.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.24",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.40",
    "@types/bcrypt": "^6.0.0",
    "@types/dockerode": "^4.0.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.1",
    "@types/nodemailer": "^8.0.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/pdf-parse": "^1.1.5",
    "@types/socket.io": "^3.0.2",
    "@types/supertest": "^7.2.0",
    "@types/tar-stream": "^3.1.4",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/ui": "^4.1.8",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.6.0",
    "madge": "^8.0.0",
    "prettier": "^3.8.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "testcontainers": "^12.0.1",
    "ts-loader": "^9.6.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.8"
  },
  "main": "index.js",
  "directories": {
    "test": "test"
  },
  "keywords": [],
  "type": "commonjs"
}
