# Environment variables for the boot integration test.
# Points at the live local infra (Postgres 5433, Redis 6380).
# These values are intentionally non-sensitive placeholders — never use in production.
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=nexus
DB_PASSWORD=nexus_password
DB_DATABASE=nexus_orchestrator
JWT_SECRET=test-secret-not-real-minimum-32-chars-pad
SECRET_ENCRYPTION_KEY=test-encryption-key-not-real-32c
# REDIS_HOST and REDIS_PORT are intentionally NOT set here.
# The OAuth login integration specs (apps/api/src/oauth/oauth-login.integration.spec.ts
# and oauth-login.worker.integration.spec.ts) gate their suite-level hooks on
# `process.env.REDIS_HOST` so they skip cleanly when the integration env is
# missing — `unset REDIS_HOST && npm run test:integration -- oauth-login` must
# report `Test Files 2 skipped (2)` rather than crashing the suite on a
# `Connection is closed.` from ioredis. The boot integration spec
# (src/app-module-boot.integration.spec.ts) is the only consumer that actually
# needs a reachable Redis; set REDIS_HOST / REDIS_PORT explicitly via the
# shell or docker compose when running that spec.
# REDIS_HOST=localhost
# REDIS_PORT=6380
CORS_ORIGIN=http://localhost:3000
NODE_ENV=test
TYPEORM_MIGRATIONS_RUN=false
