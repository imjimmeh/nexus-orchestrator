# =============================
# Nexus Orchestrator - Root .env.example
# =============================
# This file is loaded by:
# - `docker compose` (and `docker compose --profile honcho`) at the repo root
# - Nest API ConfigModule (apps/api)
# - Vitest setup for unit/e2e tests
# - Optional local runtime commands
#
# To get started, copy this file to `.env` and customise the placeholders:
#
#   cp .env.example .env
#   # edit .env — change JWT_SECRET, POSTGRES_PASSWORD, GARAGE_S3_*,
#   #   E2E_PROVIDER_API_KEY, and any port that collides on your host
#   docker compose up -d --build
#
# Compose substitutes `${VAR:-default}` from the environment first, so any
# value you set here overrides the compose-level default. Variables that are
# only consumed by the running app (Database, Redis, Auth, ...) are listed
# further down in the "Application" section.

# =====================================================
# Docker Compose Stack
# =====================================================
# Variables consumed by `docker-compose.yaml`. The `${VAR:-default}` form is
# used in the compose file, so a missing or empty value falls back to the
# default shown in the compose file. Override here only when you need a
# different host port, container name, or service image.

# -----------------------------
# Database (Postgres — main)
# -----------------------------
# These are shared by the postgres service, the API service, and the Kanban
# service. Override them together — the values must match across every
# service that connects to the same database.
POSTGRES_USER=nexus
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=nexus_orchestrator
# Host port published by the postgres service (container port is 5432).
POSTGRES_HOST_PORT=5433
# Container/image overrides (rarely needed).
POSTGRES_IMAGE=pgvector/pgvector:0.8.3-pg18
POSTGRES_CONTAINER_NAME=nexus-postgres
POSTGRES_VOLUME_NAME=nexus-postgres-data

# -----------------------------
# Redis
# -----------------------------
# Host port published by the redis service (container port is 6379).
REDIS_HOST_PORT=6380
# Container/image overrides.
REDIS_IMAGE=redis:7-alpine
REDIS_CONTAINER_NAME=nexus-redis

# -----------------------------
# API (NestJS orchestration engine)
# -----------------------------
# Host ports published by the API service. Container ports are 3000 (HTTP)
# and 3001 (WebSocket) — only change these if 3010/3011 collide on your host.
API_HTTP_HOST_PORT=3010
API_WS_HOST_PORT=3011
API_CONTAINER_NAME=nexus-api
# Public websocket URL returned to browser telemetry/kanban clients. Keep this
# host-reachable (not a Docker-internal name like nexus-api).
TELEMETRY_PUBLIC_WS_URL=http://localhost:3011

# -----------------------------
# Web UI (Vite + React)
# -----------------------------
# Host port published by the web service (container port 80).
WEB_HOST_PORT=3120

# -----------------------------
# Kanban service
# -----------------------------
# Host port published by the kanban service (container port 3012).
KANBAN_HOST_PORT=3012
KANBAN_CONTAINER_NAME=nexus-kanban
# Public websocket URL for the kanban UI.
KANBAN_PUBLIC_WS_URL=http://localhost:3012

# -----------------------------
# Honcho profile (memory backend)
# -----------------------------
# Honcho ships its own Postgres (pgvector). These credentials are isolated
# from the main database above; only the `honcho-db`, `honcho-api`, and
# `honcho-deriver` services use them, and only when you start the stack
# with `docker compose --profile honcho up -d`.
HONCHO_POSTGRES_USER=honcho
HONCHO_POSTGRES_PASSWORD=change-me-honcho-postgres-password
HONCHO_POSTGRES_DB=honcho
# Host port published by the honcho-db service (container port 5432).
HONCHO_POSTGRES_HOST_PORT=5443
HONCHO_POSTGRES_IMAGE=pgvector/pgvector:pg15
HONCHO_POSTGRES_CONTAINER_NAME=nexus-honcho-postgres
HONCHO_POSTGRES_VOLUME_NAME=nexus-honcho-postgres-data
# Honcho service images and host ports (only consumed under the `honcho`
# profile; container port is 8000).
HONCHO_IMAGE=ghcr.io/plastic-labs/honcho:latest
HONCHO_API_HOST_PORT=8030
HONCHO_API_CONTAINER_NAME=nexus-honcho-api
HONCHO_DERIVER_CONTAINER_NAME=nexus-honcho-deriver
HONCHO_AUTH_USE_AUTH=false
# Honcho client connection from the API (used when MEMORY_BACKEND=honcho|dual).
HONCHO_BASE_URL=http://honcho-api:8000
HONCHO_API_KEY=
HONCHO_DEFAULT_WORKSPACE=nexus
HONCHO_WORKSPACE_STRATEGY=global
HONCHO_REQUEST_TIMEOUT_MS=5000
HONCHO_RETRY_COUNT=1
HONCHO_FALLBACK_ON_ERROR=true
HONCHO_FALLBACK_ON_EMPTY=true

# -----------------------------
# Garage (S3 object store)
# -----------------------------
# Host port published by the garage S3 service (container port 3900). The
# garage web/admin ports (3902, 3903) are intentionally not exposed to host.
GARAGE_S3_HOST_PORT=3900
GARAGE_IMAGE=dxflrs/garage:v1.0.1
GARAGE_CONTAINER_NAME=nexus-garage
GARAGE_DATA_VOLUME_NAME=nexus-garage-data
GARAGE_META_VOLUME_NAME=nexus-garage-meta
# Public S3 endpoint and credentials surfaced to the API for client SDKs.
GARAGE_S3_ENDPOINT=http://localhost:3900
GARAGE_S3_REGION=garage
GARAGE_S3_BUCKET=nexus-uploads
GARAGE_S3_ACCESS_KEY_ID=your-access-key-id
GARAGE_S3_SECRET_ACCESS_KEY=your-secret-access-key

# -----------------------------
# Docker network / runtime wiring
# -----------------------------
# The shared Docker network that every service attaches to. Override only
# when you need to run multiple stacks side-by-side.
NEXUS_DOCKER_NETWORK=nexus-network
NEXUS_WORKSPACE_VOLUME_NAME=nexus-workspace-data

# Workspace mount root for sibling containers (defaults to a named volume).
# The API bind-mounts this path; the AgentLocal MCP and agent containers also
# resolve it on the host side. Override to an absolute host path when running
# nested Docker (docker-in-docker) so every container sees the same
# directory.
NEXUS_HOST_WORKSPACE_PATH=nexus_workspace_data

# -----------------------------
# Application passthroughs (compose -> API container)
# -----------------------------
# These variables are read by the API / Kanban / Web containers. The compose
# file passes them through with `${VAR:-default}` so the operator can override
# any of them here in `.env` without editing the compose file.

# Web UI proxy targets (relative paths are rewritten by the Vite/nginx reverse proxy).
API_URL=/api
CORE_API_URL=/api
KANBAN_API_URL=/kanban-api
CHAT_API_URL=/chat-api

# API runtime tuning
PORT=3000
NODE_ENV=development
NODE_OPTIONS=--max-old-space-size=4096
LOG_LEVEL=info
CORS_ORIGIN=*

# Public, user-facing origin used to build links in emails/invites (e.g. accept-invite).
PUBLIC_APP_URL=http://localhost:3120

# Outbound email (SMTP). Optional — when unset, invitations fall back to copyable link only.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_SECURE=false
SMTP_FROM=Nexus Orchestrator <no-reply@example.com>
# Prefer storing the SMTP password in secret_store and referencing it by id:
SMTP_PASSWORD_SECRET_ID=
# Fallback only (not recommended for production): plaintext SMTP password.
SMTP_PASSWORD=

CONTEXT_DISPATCH_BASE_URL=http://kanban:3012/api
DOCTOR_SPLIT_SERVICE_TIMEOUT_MS=3000
ORCHESTRATION_AUTO_RESTART_COOLDOWN_SECONDS=300

# Memory backend selector
MEMORY_BACKEND=postgres

# Kanban service wiring (consumed by the API to call Kanban; the Kanban
# container itself reads `KANBAN_CORE_*` from its own env block above).
KANBAN_PORT=3012
KANBAN_CORE_BASE_URL=http://api:3000/api
KANBAN_SERVICE_BASE_URL=http://kanban:3012/api
KANBAN_CORE_BEARER_TOKEN=
KANBAN_SERVICE_BEARER_TOKEN=nexus-kanban-internal-token
KANBAN_SERVICE_JWT_AUDIENCE=nexus-kanban-service
KANBAN_SERVICE_JWT_ISSUER=nexus-api
KANBAN_SERVICE_JWT_TTL=5m
KANBAN_CORE_JWT_AUDIENCE=nexus-core-internal
KANBAN_CORE_JWT_ISSUER=nexus-kanban
KANBAN_CORE_JWT_TTL=5m

# Chat / Telegram ingestion
CHAT_TELEGRAM_BOT_TOKEN=
CHAT_TELEGRAM_WEBHOOK_SECRET=
CHAT_TELEGRAM_INGRESS_MODE=webhook
CHAT_TELEGRAM_POLL_TIMEOUT_SECONDS=50
CHAT_TELEGRAM_POLL_RETRY_DELAY_MS=1000
CHAT_TELEGRAM_POLL_BACKOFF_MAX_MS=30000
CHAT_TELEGRAM_OUTBOUND_RELAY_ENABLED=true
CHAT_TELEGRAM_OUTBOUND_RELAY_INTERVAL_MS=3000
CHAT_TELEGRAM_OUTBOUND_RELAY_BATCH_SIZE=20
CHAT_TELEGRAM_DEFAULT_AGENT_PROFILE=friendly-general-assistant
CHAT_TELEGRAM_DEFAULT_PROJECT_ID=
CHAT_TELEGRAM_ALLOWED_USER_IDS=

# -----------------------------
# Application
# -----------------------------
# (PORT / NODE_ENV / LOG_LEVEL are declared in the "Docker Compose Stack"
# section above as compose passthroughs. The DB / Redis / Docker / Auth
# blocks below are read directly by the API process when it boots outside
# the compose stack — e.g. during `npm run start:api` for local dev.)

# -----------------------------
# Database (API)
# -----------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=nexus_orchestrator

# -----------------------------
# Redis + BullMQ (API)
# -----------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
BULLMQ_QUEUE_NAME=bull:workflow_steps

# -----------------------------
# Docker access (API)
# -----------------------------
# Use either DOCKER_SOCKET_PATH (Linux/macOS) or DOCKER_HOST (remote daemon)
DOCKER_SOCKET_PATH=/var/run/docker.sock
DOCKER_HOST=

# Skills library host mount for docker compose
# This host path is mounted to /data/nexus-skills in the API container.
NEXUS_HOST_SKILLS_PATH=./storage/skills

# Root seed directory host mount for docker compose
# This host path is mounted read-only to /app/seed in the API container.
NEXUS_HOST_SEED_PATH=./seed

# Tool mount host path for docker compose (sibling-container remap).
# API mounts this root at /tmp/nexus-tools. Set to an absolute host path
# when running docker-in-docker so sibling agent containers resolve correctly.
NEXUS_HOST_TOOL_MOUNT_PATH=./data/tool-mounts

# Checkpoint sidecar host path for docker compose (sibling-container remap).
# API mounts this root at /tmp/nexus-checkpoints. Set to an absolute host path
# when running docker-in-docker so sibling agent containers and the supervisor
# share the same directory on the Docker host.
NEXUS_HOST_CHECKPOINT_PATH=./data/checkpoints
# Set to true or 1 to enable exact-point session resume (checkpoint mount, persist-on-reap, resume lookup). Default: off.
SESSION_CHECKPOINT_RESUME_ENABLED=false

# Host-share mount root for governed host file access (EPIC-100).
# API mounts this root at /data/nexus-host-shares.
# For nested Docker remap, prefer an absolute host path.
NEXUS_HOST_SHARE_MOUNT_PATH=
NEXUS_API_HOST_SHARE_BASE_PATH=/data/nexus-host-shares

# Optional JSON override for host mount catalog aliases.
# Example:
# {"project_docs":{"api_root":"/data/nexus-host-shares/project-docs","default_mode":"ro","writable_allowed":false}}
NEXUS_HOST_MOUNT_CATALOG_JSON=

# -----------------------------
# Auth + Security (API)
# -----------------------------

# JWT Configuration
# IMPORTANT: Change JWT_SECRET in production! Must be at least 32 characters
JWT_SECRET=nexus-secret-key
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_REFRESH_REMEMBER_ME=30d

# HMAC key used to derive an indexable hash of opaque refresh tokens so the
# API can look them up in O(1) instead of bcrypt-comparing every stored token.
# Leave unset to derive a stable value from JWT_SECRET (label:
# 'derived-from-jwt-secret'); set an explicit value to rotate independently of
# JWT_SECRET. Must be at least 32 characters whenever provided.
REFRESH_TOKEN_HMAC_KEY=

# Password Policy Settings
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL=true
PASSWORD_BCRYPT_ROUNDS=12

# Rate Limiting Settings
RATE_LIMIT_TTL=60
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_AUTH_TTL=60
RATE_LIMIT_AUTH_REQUESTS=5

# Other Security
SECRET_ENCRYPTION_KEY=
WEBHOOK_SECRET=change-me-webhook-secret

# -----------------------------
# Workflow / Agent runtime wiring (API -> pi-runner)
# -----------------------------
# Internal websocket URL advertised to agent containers. The public URL
# surfaced to browser clients is `TELEMETRY_PUBLIC_WS_URL` (declared in the
# "Docker Compose Stack" section above).
WEBSOCKET_URL=http://host.docker.internal:3001

# -----------------------------
# AI model fallbacks (API)
# DB defaults are preferred; these are fallback values.
# -----------------------------
MODEL=
DISTILLATION_MODEL=
SUMMARIZATION_MODEL=

# -----------------------------
# Optional provider credentials fallback
# (Used by pi-runner or test bootstrap paths)
# -----------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
AZURE_OPENAI_API_KEY=

# -----------------------------
# Observability
# -----------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces

# -----------------------------
# E2E test configuration
# -----------------------------
RUN_LIVE_E2E=false
E2E_API_URL=http://127.0.0.1:3010
E2E_WS_URL=http://127.0.0.1:3011
E2E_JWT_SECRET=

# Optional explicit workflow input overrides in e2e YAML
E2E_MODEL=
E2E_PROVIDER=

# Live e2e AI config bootstrap
E2E_PROVIDER_NAME=
E2E_MODEL_NAME=
E2E_AGENT_PROFILE_NAME=
E2E_PROVIDER_API_KEY=
E2E_OPENAI_API_KEY=
E2E_PROVIDER_SECRET_KEY=OPENAI_API_KEY
E2E_PROVIDER_SECRET_NAME=
E2E_PROVIDER_BASE_URL=

# Optional DB startup seed bootstrap from env credentials
# When true, database startup seeds secret_store from E2E_PROVIDER_API_KEY / E2E_OPENAI_API_KEY / OPENAI_API_KEY
SEED_LLM_SECRET_FROM_ENV=false

# Optional startup seed path overrides (API)
NEXUS_SKILLS_SEED_PATH=./seed/skills
NEXUS_AGENTS_SEED_PATH=./seed/agents
NEXUS_AGENT_SKILL_ASSIGNMENTS_SEED_PATH=./seed/agents/skill-assignments.seed.json
NEXUS_WORKFLOWS_SEED_PATH=./seed/workflows

# EPIC-070 feature toggles
EXTERNAL_PROMPTS_ENABLED=true
STRICT_SKILL_VALIDATION=false
WORKFLOW_DRY_RUN=true

# Memory context injection guard (graduated rollout).
# When true, retrieved `memory_context` is included in agent prompts.
# Set to false to skip assembly and force `memory_context=null` at the
# workflow input layer (e.g. for incident rollback). Default: true.
MEMORY_CONTEXT_INJECTION_ENABLED=true

# Memory token budget (API distillation resolver).
# Slices the active model's context window into three mutually exclusive
# partitions consumed by `MemoryTokenBudgetResolver`: MEMORY (long-term
# recall), WORKING (recent turns, tool results, scratchpad), and RESERVED
# (system prompt, formatting, output headroom). Percentages are applied on
# top of the resolved context window and must sum to <= 100; invalid or
# missing values fall back to the named defaults exported from
# `apps/api/src/memory/memory-token-budget.resolver.ts`.
MEMORY_BUDGET_MEMORY_PERCENT=60
MEMORY_BUDGET_WORKING_PERCENT=30
MEMORY_BUDGET_RESERVED_PERCENT=10

# Fallback context window (in tokens) used by `MemoryTokenBudgetResolver`
# when no active model is configured for the distillation use case, or when
# the configured model reports a non-positive token limit. Defaults to
# 128000 to preserve the historical hardcoded behaviour of the memory
# subsystem. Must be a positive integer when set.
MEMORY_BUDGET_FALLBACK_CONTEXT_WINDOW=128000

# Durable agent-await: when the orchestration CEO cycle decides to run discovery
# and/or backlog planning, it spawns AND awaits those child workflows via the
# await_agent_workflow capability so the cycle stays parked until they finish.
# Enabled by default; set to false to disable the capability (the await action
# is then rejected and prompts fall back to fire-and-forget delegation).
ORCHESTRATION_AWAIT_ENABLED=true

# Grace window (ms) before the agent-await reconciler retries a stuck `RESUMING`
# await whose container provisioning was interrupted (e.g. an API restart mid-resume).
# Defaults to 120000 (2 min). Must be a positive integer; invalid values fall back to the default.
AGENT_AWAIT_RESUME_GRACE_MS=120000

# -----------------------------
# pi-runner direct runtime variables
# (Normally injected by orchestrator for agent containers)
# -----------------------------
AGENT_JWT=
WORKFLOW_RUN_ID=
TEMPERATURE=0.7
RESUME_NODE_ID=
SYSTEM_PROMPT=

# Garage S3 client credentials and bucket name are declared in the
# "Docker Compose Stack" section above (GARAGE_S3_*).

# -----------------------------
# Attachments Module
# -----------------------------
# Server-side: enables the upload/link/list endpoints (default off)
ATTACHMENTS_ENABLED=false
ATTACHMENTS_MAX_SIZE_BYTES=26214400
ATTACHMENTS_IMAGE_VISION_EAGER=true
ATTACHMENTS_IMAGE_VISION_BATCH_CAP=5

# Frontend (Vite): shows the attach button and file upload UI (default off).
# Must match ATTACHMENTS_ENABLED to keep API and UI in sync.
VITE_ATTACHMENTS_ENABLED=false
